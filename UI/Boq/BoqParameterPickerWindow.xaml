<Window
    x:Class="Pulse.UI.Boq.BoqParameterPickerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:Pulse.UI"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="BOQ Parameter Picker"
    Width="600"
    Height="480"
    MinWidth="480"
    MinHeight="360"
    AllowsTransparency="True"
    Background="Transparent"
    WindowStyle="None"
    WindowStartupLocation="CenterOwner"
    MouseMove="Window_MouseMove"
    MouseUp="Window_MouseUp"
    mc:Ignorable="d">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesignTheme.Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Pulse;component/UI/Themes/ElementStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Column list style -->
            <Style x:Key="PickerListBoxStyle" TargetType="ListBox">
                <Setter Property="Background"     Value="{DynamicResource PrimaryBackgroundBrush}" />
                <Setter Property="Foreground"     Value="{DynamicResource ForegroundBrush}" />
                <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
            </Style>

            <Style x:Key="PickerListBoxItemStyle" TargetType="ListBoxItem">
                <Setter Property="Padding"     Value="8,5" />
                <Setter Property="Foreground"  Value="{DynamicResource ForegroundBrush}" />
                <Setter Property="Background"  Value="Transparent" />
                <Setter Property="FontSize"    Value="12" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource SelectionHoverBrush}" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="{DynamicResource HighlightBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>

        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="Transparent" ClipToBounds="True">

        <!-- Frosted-glass edge glow -->
        <Border BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="2"
                ClipToBounds="True"
                CornerRadius="10"
                Opacity="0.7"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <BlurEffect KernelType="Gaussian" Radius="2" />
            </Border.Effect>
        </Border>

        <!-- Main surface -->
        <Border Margin="2"
                Background="{DynamicResource PrimaryBackgroundBrush}"
                CornerRadius="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"   />  <!-- Title bar -->
                    <RowDefinition Height="*"    />  <!-- Content   -->
                    <RowDefinition Height="Auto" />  <!-- Footer    -->
                </Grid.RowDefinitions>

                <!-- Row 0 — Title bar -->
                <ui:TitleBar Grid.Row="0"
                             IsMinimizeVisible="False"
                             Foreground="{DynamicResource IconBrush}" />

                <!-- Row 1 — Content -->
                <Grid Grid.Row="1" Margin="16,12,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"    />  <!-- Available -->
                        <ColumnDefinition Width="48"   />  <!-- Buttons   -->
                        <ColumnDefinition Width="*"    />  <!-- Chosen    -->
                    </Grid.ColumnDefinitions>

                    <!-- Available parameters -->
                    <DockPanel Grid.Column="0">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="DatabaseOutline" Width="13" Height="13"
                                                     Foreground="{DynamicResource IconForegroundBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="AVAILABLE IN REVIT"
                                       Style="{StaticResource FieldLabelStyle}" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Available}"
                                 SelectedItem="{Binding SelectedAvailable}"
                                 Style="{StaticResource PickerListBoxStyle}"
                                 ItemContainerStyle="{StaticResource PickerListBoxItemStyle}"
                                 DisplayMemberPath="Header" />
                    </DockPanel>

                    <!-- Move buttons -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Margin="4,0">

                        <Button Command="{Binding AddCommand}"
                                Style="{StaticResource PulsePrimaryButtonStyle}"
                                ToolTip="Add to BOQ"
                                Width="34" Height="28"
                                Padding="0"
                                Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="ChevronRight" Width="16" Height="16" />
                        </Button>

                        <Button Command="{Binding RemoveCommand}"
                                Style="{StaticResource PulseActionButtonStyle}"
                                ToolTip="Remove from BOQ"
                                Width="34" Height="28"
                                Padding="0">
                            <materialDesign:PackIcon Kind="ChevronLeft" Width="16" Height="16" />
                        </Button>

                    </StackPanel>

                    <!-- Chosen (Show in BOQ) parameters -->
                    <DockPanel Grid.Column="2">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <materialDesign:PackIcon Kind="TableLarge" Width="13" Height="13"
                                                     Foreground="{DynamicResource IconForegroundBrush}"
                                                     VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="SHOW IN BOQ"
                                       Style="{StaticResource FieldLabelStyle}" />
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Chosen}"
                                 SelectedItem="{Binding SelectedChosen}"
                                 Style="{StaticResource PickerListBoxStyle}"
                                 ItemContainerStyle="{StaticResource PickerListBoxItemStyle}"
                                 DisplayMemberPath="Header" />
                    </DockPanel>
                </Grid>

                <!-- Row 2 — Footer -->
                <Border Grid.Row="2"
                        Background="{DynamicResource SecondaryBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,8,8"
                        Padding="12,8">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding CancelCommand}"
                                Style="{StaticResource PulseActionButtonStyle}"
                                Margin="0,0,6,0">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Close" Width="13" Height="13"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Cancel" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OkCommand}"
                                Style="{StaticResource PulsePrimaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Check" Width="13" Height="13"
                                                         VerticalAlignment="Center" Margin="0,0,4,0" />
                                <TextBlock Text="Apply" FontSize="11" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- Resize grips -->
        <Border x:Name="ResizeLeft"        Width="5"  HorizontalAlignment="Left"   Background="Transparent" Cursor="SizeWE"   MouseDown="ResizeLeft_MouseDown"/>
        <Border x:Name="ResizeRight"       Width="5"  HorizontalAlignment="Right"  Background="Transparent" Cursor="SizeWE"   MouseDown="ResizeRight_MouseDown"/>
        <Border x:Name="ResizeBottom"      Height="5" VerticalAlignment="Bottom"   Background="Transparent" Cursor="SizeNS"   MouseDown="ResizeBottom_MouseDown"/>
        <Border x:Name="ResizeBottomLeft"  Width="10" Height="10" HorizontalAlignment="Left"  VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNESW" MouseDown="ResizeBottomLeft_MouseDown"/>
        <Border x:Name="ResizeBottomRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Background="Transparent" Cursor="SizeNWSE" MouseDown="ResizeBottomRight_MouseDown"/>
    </Grid>
</Window>
